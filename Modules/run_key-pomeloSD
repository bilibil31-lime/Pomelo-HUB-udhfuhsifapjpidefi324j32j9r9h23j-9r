local isClosed = false
local function CloseUI()
    if isClosed then return end
    isClosed = true
    local t = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
    t:Play()
    t.Completed:Wait()
    ScreenGui:Destroy()
end

