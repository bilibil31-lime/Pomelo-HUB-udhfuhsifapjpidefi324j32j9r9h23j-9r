local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")

local UPDATE_URL = "https://raw.githubusercontent.com/bilibil31-lime/ilikepomelo555tyGGbyeJJK10101/main/Core/pomelo_update.lua"
local KEY_SCRIPT_URL = "https://raw.githubusercontent.com/bilibil31-lime/ilikepomelo555tyGGbyeJJK10101/main/Modules/run_key-pomeloSD"
local MESSAGE_URL = "https://raw.githubusercontent.com/bilibil31-lime/ilikepomelo555tyGGbyeJJK10101/main/Modules/mod_Update.lua"

-- 1. เช็คสถานะจาก GitHub
local fetchUrl = UPDATE_URL .. "?t=" .. tostring(os.time())
local success, response = pcall(function() return game:HttpGet(fetchUrl) end)
local answer = "3" 

if success and response then
    local match = string.match(response, "Answer%s*=%s*(%d+)")
    if match then
        answer = match
    end
end

-- 2. ถ้า Answer = 3 ให้รันระบบ Key ทันทีโดยไม่แสดง UI
if answer == "3" then
    pcall(function()
        loadstring(game:HttpGet(KEY_SCRIPT_URL))()
    end)
    return
end

-- 3. ดึงข้อความอธิบายจาก mod_Update.lua
local customMessage = "System is currently unavailable."
local msgUrl = MESSAGE_URL .. "?t=" .. tostring(os.time())
local msgSuccess, msgResponse = pcall(function() return game:HttpGet(msgUrl) end)

if msgSuccess and msgResponse then
    local patternWithNext = "%[" .. answer .. "%](.-)%[%d+%]"
    local patternEnd = "%[" .. answer .. "%](.*)"
    
    local extracted = string.match(msgResponse, patternWithNext)
    if not extracted then
        extracted = string.match(msgResponse, patternEnd)
    end
    
    if extracted then
        customMessage = extracted:match("^%s*(.-)%s*$")
    end
end

-- 4. สร้าง UI กรณีสถานะไม่ใช่ 3
local function DestroyOldUI()
    local targetParents = {CoreGui}
    if gethui then table.insert(targetParents, gethui()) end
    local LP = Players.LocalPlayer
    if LP and LP:FindFirstChild("PlayerGui") then table.insert(targetParents, LP.PlayerGui) end
    for _, parent in ipairs(targetParents) do
        for _, child in ipairs(parent:GetChildren()) do
            if child.Name == "PomeloNoticeUI" then child:Destroy() end
        end
    end
end
DestroyOldUI()

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "PomeloNoticeUI"
ScreenGui.ResetOnSpawn = false

local function SafeSetParent()
    local successParent = pcall(function() ScreenGui.Parent = gethui and gethui() or CoreGui end)
    if not successParent then
        local LP = Players.LocalPlayer
        while not LP do Players:GetPropertyChangedSignal("LocalPlayer"):Wait(); LP = Players.LocalPlayer end
        ScreenGui.Parent = LP:WaitForChild("PlayerGui")
    end
end
SafeSetParent()

